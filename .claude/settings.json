{
  "permissions": {
    "additionalDirectories": [
      "/Users/amar/.claude/agents",
      "/Users/amar/.claude/skills"
    ],
    "allow": [
      "Edit(~/.claude/skills/apex-ai-product/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status --json",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph detect-changes --brief",
            "if": "Bash(git commit*)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
