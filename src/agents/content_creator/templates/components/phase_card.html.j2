<div class="p-6 rounded-[28px] border border-white/10 bg-white/[0.03] backdrop-blur-md transition-all duration-300 hover:border-white/25">
  <div class="flex items-center gap-3 mb-3">
    <span class="w-2.5 h-2.5 rounded-full {% if status == 'complete' %}bg-emerald-400{% elif status == 'active' %}bg-amber-400 animate-pulse{% else %}bg-stone-500{% endif %}"></span>
    <h4 class="text-lg font-semibold text-stone-100 tracking-tight">{{ phase }}</h4>
  </div>
  {% if description %}<p class="text-sm text-stone-300/72 leading-7">{{ description }}</p>{% endif %}
  {% if progress_pct > 0 %}
  <div class="mt-4 h-1 rounded-full bg-white/10 overflow-hidden">
    <div class="h-full rounded-full bg-stone-300/40 transition-all duration-500" style="width: {{ progress_pct }}%"></div>
  </div>
  {% endif %}
</div>
