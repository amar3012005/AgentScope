<div class="relative p-8 rounded-[32px] border border-white/12 bg-gradient-to-br from-white/[0.07] to-transparent backdrop-blur-md overflow-hidden">
  <div class="absolute -top-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
  <p class="text-lg md:text-2xl text-stone-100/92 leading-relaxed italic font-['Cormorant_Garamond'] relative z-10">{{ text }}</p>
  {% if attribution %}<span class="block mt-4 text-sm text-stone-400/60 relative z-10">&mdash; {{ attribution }}</span>{% endif %}
</div>
