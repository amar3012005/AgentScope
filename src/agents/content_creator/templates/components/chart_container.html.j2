<div class="p-6 rounded-[28px] border border-white/10 bg-white/[0.03] backdrop-blur-md">
  {% if title %}<h3 class="text-lg font-semibold text-stone-100 tracking-tight mb-4 font-['Cormorant_Garamond']">{{ title }}</h3>{% endif %}
  <div class="relative" style="max-height: 320px;">
    <canvas data-chart-config='{{ chart_config | tojson }}'></canvas>
  </div>
  {% if caption %}<p class="text-stone-400/60 text-xs mt-3">{{ caption }}</p>{% endif %}
</div>
