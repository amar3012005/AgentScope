<style>
  :root {
    --poster-max-width: {{ blueprint.layout.max_width | default('1200px') }};
    --poster-section-spacing: {{ blueprint.layout.section_spacing | default('22px') }};
    --poster-grid-step: {{ blueprint.layout.grid_step | default('42px') }};
  }
</style>
<div class="min-h-screen relative overflow-hidden" style="background:
  radial-gradient(circle at 0% 0%, color-mix(in srgb, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 12%, transparent), transparent 28%),
  radial-gradient(circle at 100% 100%, color-mix(in srgb, {{ tokens.secondary | default(tokens.muted | default('#A1A19B')) }} 16%, transparent), transparent 34%),
  linear-gradient(145deg, {{ tokens.background | default('#0f0f10') }}, color-mix(in srgb, {{ tokens.surface | default(tokens.background | default('#0f0f10')) }} 82%, {{ tokens.primary | default('#F5F5F1') }} 18%));">
  <div class="absolute inset-0 pointer-events-none" style="background-image:
    linear-gradient(color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 4%, transparent) 1px, transparent 1px),
    linear-gradient(90deg, color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 4%, transparent) 1px, transparent 1px);
    background-size: var(--poster-grid-step) var(--poster-grid-step);
    mask-image: radial-gradient(circle at center, black 42%, transparent 100%);"></div>

  <div class="relative z-10 mx-auto flex min-h-screen flex-col justify-between py-6"
       style="max-width: var(--poster-max-width); gap: var(--poster-section-spacing);">
    {% for section in sections %}
    <div class="vangogh-section" style="animation-delay: {{ loop.index0 * 0.12 }}s">
      {{ section.html_fragment }}
    </div>
    {% endfor %}
  </div>
</div>
