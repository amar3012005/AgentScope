<section class="relative overflow-hidden px-8 py-10 md:px-12 md:py-12">
  <div class="absolute inset-0 pointer-events-none" style="background:
    radial-gradient(circle at 12% 18%, color-mix(in srgb, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 18%, transparent), transparent 36%),
    radial-gradient(circle at 88% 20%, color-mix(in srgb, {{ tokens.secondary | default(tokens.muted | default('#A1A19B')) }} 20%, transparent), transparent 32%),
    linear-gradient(135deg, color-mix(in srgb, {{ tokens.background | default('#0f0f10') }} 94%, {{ tokens.primary | default('#F5F5F1') }} 6%), {{ tokens.surface | default(tokens.background | default('#0f0f10')) }} 58%, color-mix(in srgb, {{ tokens.background | default('#0f0f10') }} 88%, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 12%));"></div>

  <div class="relative z-10 grid gap-8 {% if alignment == 'center' %}text-center justify-items-center{% endif %}">
    <div class="flex flex-wrap items-center gap-3 {% if alignment == 'center' %}justify-center{% endif %}">
      {% if eyebrow %}
      <span class="inline-flex items-center rounded-full px-3 py-1 text-[10px] font-medium uppercase tracking-[0.22em]" style="background: color-mix(in srgb, {{ tokens.surface | default('#171718') }} 84%, transparent); border: 1px solid color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 18%, transparent); color: color-mix(in srgb, {{ tokens.ink | default('#E8E7E2') }} 86%, transparent);">
        {{ eyebrow }}
      </span>
      {% endif %}
      {% if poster_type %}
      <span class="text-[10px] font-mono uppercase tracking-[0.18em]" style="color: color-mix(in srgb, {{ tokens.muted | default('#A1A19B') }} 90%, transparent);">
        {{ poster_type }}
      </span>
      {% endif %}
      {% if visual_motif %}
      <span class="text-[10px] font-mono uppercase tracking-[0.18em]" style="color: color-mix(in srgb, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 84%, transparent);">
        {{ visual_motif }}
      </span>
      {% endif %}
    </div>

    <div class="max-w-5xl">
      <h1 class="text-5xl font-semibold uppercase tracking-[-0.06em] md:text-7xl lg:text-[6.5rem] leading-[0.92] font-['Cormorant_Garamond']" style="color: {{ tokens.primary | default('#F5F5F1') }};">
        {{ headline }}
      </h1>
      {% if subheadline %}
      <p class="mt-5 max-w-3xl text-base leading-7 md:text-xl md:leading-9 {% if alignment == 'center' %}mx-auto{% endif %}" style="color: color-mix(in srgb, {{ tokens.ink | default('#E8E7E2') }} 84%, transparent);">
        {{ subheadline }}
      </p>
      {% endif %}
      {% if supporting_line %}
      <p class="mt-4 text-[11px] font-medium uppercase tracking-[0.22em]" style="color: color-mix(in srgb, {{ tokens.muted | default('#A1A19B') }} 90%, transparent);">
        {{ supporting_line }}
      </p>
      {% endif %}
    </div>

    {% if focal_image_prompt %}
    <div class="max-w-2xl {% if alignment == 'center' %}mx-auto{% endif %}">
      <div class="rounded-[2rem] p-5 backdrop-blur-sm" style="border: 1px solid color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 14%, transparent); background: linear-gradient(135deg, color-mix(in srgb, {{ tokens.surface | default('#171718') }} 84%, transparent), color-mix(in srgb, {{ tokens.surface | default('#171718') }} 64%, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 14%));">
        <div class="text-[10px] font-mono uppercase tracking-[0.18em]" style="color: color-mix(in srgb, {{ tokens.muted | default('#A1A19B') }} 92%, transparent);">Visual Direction</div>
        <p class="mt-3 text-sm leading-7" style="color: color-mix(in srgb, {{ tokens.ink | default('#E8E7E2') }} 82%, transparent);">
          {{ focal_image_prompt }}
        </p>
      </div>
    </div>
    {% endif %}
  </div>
</section>
