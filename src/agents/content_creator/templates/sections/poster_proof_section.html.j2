<section class="px-8 py-8 md:px-12">
  <div class="rounded-[2.2rem] p-6 md:p-8" style="background: linear-gradient(160deg, color-mix(in srgb, {{ tokens.surface | default('#171718') }} 92%, transparent), color-mix(in srgb, {{ tokens.surface | default('#171718') }} 76%, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 12%)); border: 1px solid color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 12%, transparent);">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1.4fr)] lg:items-start">
      <div>
        {% if title %}
        <div class="text-[11px] font-mono uppercase tracking-[0.18em]" style="color: color-mix(in srgb, {{ tokens.muted | default('#A1A19B') }} 92%, transparent);">{{ title }}</div>
        {% endif %}
        {% if lead_metric %}
        <div class="mt-4 text-5xl font-semibold tracking-[-0.06em] md:text-7xl font-['Cormorant_Garamond']" style="color: {{ tokens.primary | default('#F5F5F1') }};">{{ lead_metric }}</div>
        {% endif %}
        {% if lead_label %}
        <div class="mt-2 text-sm uppercase tracking-[0.18em]" style="color: color-mix(in srgb, {{ tokens.ink | default('#E8E7E2') }} 78%, transparent);">{{ lead_label }}</div>
        {% endif %}
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {% for item in proof_items %}
        <div class="rounded-[1.6rem] p-4" style="background: color-mix(in srgb, {{ tokens.background | default('#0f0f10') }} 40%, {{ tokens.surface | default('#171718') }} 60%); border: 1px solid color-mix(in srgb, {{ tokens.primary | default('#F5F5F1') }} 10%, transparent);">
          <div class="flex items-center justify-between gap-3">
            {% if item.label %}
            <span class="text-[10px] font-mono uppercase tracking-[0.16em]" style="color: color-mix(in srgb, {{ tokens.muted | default('#A1A19B') }} 90%, transparent);">{{ item.label }}</span>
            {% endif %}
            <span class="text-[10px] uppercase tracking-[0.16em]" style="color: color-mix(in srgb, {{ tokens.accent | default(tokens.primary | default('#F5F5F1')) }} 84%, transparent);">{{ item.emphasis }}</span>
          </div>
          <div class="mt-3 text-xl font-semibold leading-7 tracking-[-0.03em]" style="color: {{ tokens.primary | default('#F5F5F1') }};">{{ item.headline }}</div>
          {% if item.detail %}
          <p class="mt-2 text-sm leading-7" style="color: color-mix(in srgb, {{ tokens.ink | default('#E8E7E2') }} 78%, transparent);">{{ item.detail }}</p>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
