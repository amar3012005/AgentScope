# ============================================================
# GraphRAG Optimized - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================
# REQUIRED: Qdrant Vector Database
# ============================================================
# Your Qdrant instance URL (cloud or self-hosted)
QDRANT_URL=https://qdrant.api.blaiq.ai

# Qdrant API Key for authentication
QDRANT_API_KEY=your_qdrant_api_key_here

# Collection name (tenant-scoped in production)
QDRANT_COLLECTION=bundb_app_blaiq_ai_knowledgeglobal_421771263939368kqddYuPaFFkbH-Mll4RPn

# ============================================================
# REQUIRED: OpenAI-Compatible LLM
# ============================================================
# OpenAI API Key (or compatible provider)
OPENAI_API_KEY=your_openai_api_key_here

# API Base URL (OpenAI-compatible proxy)
OPENAI_API_BASE_URL=https://api.blaiq.ai/v1

# Fallback model path (non-Groq fallback via LiteLLM/OpenAI-compatible route)
OPENAI_MODEL=gemini-2.5-flash-lite

# Optional: Secondary fallback model
OPENAI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Content Design Agent - Creates content structure and narrative (Vertex AI Claude Sonnet 4.6)
CONTENT_DESIGN_MODEL=vertex_ai/claude-sonnet-4-6@default

# Content Analysis Agent - Analyzes existing content and extracts insights (cost-effective mini model)
CONTENT_ANALYSIS_MODEL=gpt-4o-mini

# Gap Analysis Agent - Identifies content gaps and opportunities (cost-effective mini model)
GAP_ANALYSIS_MODEL=gpt-4o-mini

# Primary Groq model routing for retrieval/generation
LITELLM_PRE_MODEL=gpt-4o-mini
LITELLM_PLANNER_MODEL=gpt-4o-mini
LITELLM_POST_MODEL=gemini-2.5-pro
LITELLM_REFORMAT_MODEL=groq/llama-3.3-70b-versatile

# Strategist Agent - High-level planning and strategy (cost-effective mini model)
LITELLM_STRATEGIST_MODEL=gpt-4o-mini

# Optional: LLM timeout and token limits
LLM_TIMEOUT_SECONDS=25
LLM_MAX_OUTPUT_TOKENS=4000
FINAL_REASONING_EFFORT=medium
FINAL_REASONING_EFFORT_GPT_OSS=low

# Retrieval tuning (latency/recall tradeoff)
KEYWORD_TIME_BUDGET_S=0.9
KEYWORD_MAX_TERMS=6
KEYWORD_PER_CALL_TIMEOUT_S=0.7
KEYWORD_PER_TERM_LIMIT=40
DOCID_TIME_BUDGET_S=0.7
DOCID_MAX_TERMS=6
DOCID_PER_CALL_TIMEOUT_S=0.6
DOCID_PER_TERM_LIMIT=25

# ============================================================
# OPTIONAL: Neo4j Graph Database (for graph features)
# ============================================================
# Neo4j connection URI
# Examples:
#   - Local: bolt://localhost:7687
#   - Cloud: neo4j+s://your-instance.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ============================================================
# OPTIONAL: BGE-M3 Embedding Service
# ============================================================
# If using external BGE-M3 service (otherwise uses local)
BGE_M3_SERVICE_URL=
BGE_M3_API_KEY=
BGE_M3_MODEL_ID=BAAI/bge-m3

# ============================================================
# Redis Cache Configuration
# ============================================================
# Redis URL (auto-configured in docker-compose)
REDIS_URL=redis://localhost:6379

# Enable/disable caching
ENABLE_CACHE=true

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# ============================================================
# API Security
# ============================================================
# API Key for securing endpoints (optional but recommended)
API_KEY=your_secure_api_key_here

# ============================================================
# Service Configuration
# ============================================================
# Service version tag
VERSION=latest
HOST_PORT=8020
BLAIQ_CORE_PORT=6000
BLAIQ_ECHO_AGENT_PORT=6002
BLAIQ_GRAPH_RAG_PORT=6001

# BLAIQ-CORE orchestrator defaults
BLAIQ_DEFAULT_AGENT=blaiq-graph-rag
BLAIQ_GRAPHRAG_AGENT=blaiq-graph-rag
BLAIQ_GRAPHRAG_TIMEOUT_SECONDS=180
STRATEGIST_ENABLED=true
TENANT_CONFIG_MAP_JSON={"default":{"tenant_id":"default","qdrant_url":"http://qdrant-test:6333","qdrant_api_key":"apikey12345678","collection_name":"default","neo4j_uri":"bolt://neo4j-test:7687","neo4j_user":"neo4j","neo4j_password":"password12345678"}}

# Optional per-tenant overrides. Core resolves these dynamically from `tenant_id`.
# Example for tenant_id=acme:
# TENANT_ACME_QDRANT_URL=http://qdrant-test:6333
# TENANT_ACME_QDRANT_API_KEY=apikey12345678
# TENANT_ACME_COLLECTION_NAME=acme
# TENANT_ACME_NEO4J_URI=bolt://neo4j-test:7687
# TENANT_ACME_NEO4J_USER=neo4j
# TENANT_ACME_NEO4J_PASSWORD=password12345678

# ============================================================
# SUMMARY OF REQUIRED KEYS
# ============================================================
# Minimum required to run:
# 1. QDRANT_URL - Your Qdrant instance
# 2. QDRANT_API_KEY - Qdrant authentication
# 3. OPENAI_API_KEY - For LLM operations
#
# Optional but recommended:
# 4. NEO4J_PASSWORD - For graph features
# 5. API_KEY - For API security
# ============================================================
